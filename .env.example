# Supabase (shared with foreducator.com — see docs/supabase-pm-conventions.md)
# Project ref: jmgoqpqyrnoamfjngcmy
# Server-only vars (browser client is not used), matching Vercel's PM_ prefix.
# lib/supabase/env.ts also falls back to NEXT_PUBLIC_PM_* if set.
PM_SUPABASE_URL=https://jmgoqpqyrnoamfjngcmy.supabase.co
PM_SUPABASE_ANON_KEY=eyJhbGciOi...your_anon_key
# NEXT_PUBLIC_PM_SUPABASE_URL=
# NEXT_PUBLIC_PM_SUPABASE_ANON_KEY=

# 학생 로그인 세션 쿠키 서명용 (서버 전용, 긴 랜덤 문자열)
PM_STUDENT_SESSION_SECRET=replace_with_long_random_string

# pimath 프로덕션 canonical origin (OAuth·이메일 인증 redirectTo용)
# 로컬에서는 비워 두고 request headers를 사용합니다.
PM_SITE_URL=https://pimath.kr

# Google Analytics 4 (프로덕션에서만 로드)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-9122HY9024
